{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "lib/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "tests/**/*.mjs",
    "tests/**/*.ts",
    "scripts/**/*.mjs"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "lib/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts"
  ],
  "ignore": [
    ".next/**",
    "node_modules/**",
    "data/**"
  ]
}
